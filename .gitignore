# =============================================================================
# pydiskmark — Python .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python bytecode & caches
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---------------------------------------------------------------------------
# Distribution / packaging
# ---------------------------------------------------------------------------
*.egg-info/
*.egg
dist/
build/
wheels/
sdist/
.eggs/
MANIFEST

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.virtualenv/

# ---------------------------------------------------------------------------
# pip / uv / installer caches
# ---------------------------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt
.pip/

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.lcov
nosetests.xml
test-results/

# ---------------------------------------------------------------------------
# Type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.pytype/
.pyre/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# IDE / editor artefacts
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# pydiskmark runtime files
# ---------------------------------------------------------------------------
# Test data written during benchmarks
pdm-data/
testdata*.pdm

# Exported benchmark results (these belong to the user, not the repo)
*.pdm.json
*.pdm.yml
*.pdm.yaml
*.pdm.csv

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.yaml
secrets.json
